#!/bin/zsh
# Start Emacs in daemon mode (emacs-plus cask).
#
# emacs-plus injects PATH at install time, so no login-shell
# sourcing is needed. The CLI wrapper inside Emacs.app sets up
# the native-compilation environment automatically.
#
# Usage: emacs-daemon [start|stop|restart|status]

set -euo pipefail

EMACS="/Applications/Emacs.app/Contents/MacOS/bin/emacs"
EMACSCLIENT="/Applications/Emacs.app/Contents/MacOS/bin/emacsclient"

_is_running() {
  "$EMACSCLIENT" -e '(+ 1 0)' >/dev/null 2>&1
}

_start() {
  if _is_running; then
    echo "Emacs daemon is already running."
    return 0
  fi
  echo "Starting Emacs daemon..."
  "$EMACS" --daemon
  echo "Emacs daemon started."
}

_stop() {
  if ! _is_running; then
    echo "Emacs daemon is not running."
    return 0
  fi
  echo "Stopping Emacs daemon..."
  "$EMACSCLIENT" -e '(kill-emacs)' >/dev/null 2>&1 || true
  echo "Emacs daemon stopped."
}

_restart() {
  _stop
  sleep 1
  _start
}

_status() {
  if _is_running; then
    local version
    version=$("$EMACSCLIENT" -e '(emacs-version)' 2>/dev/null)
    echo "Emacs daemon is running: $version"
  else
    echo "Emacs daemon is not running."
    return 1
  fi
}

case "${1:-start}" in
  start)   _start   ;;
  stop)    _stop    ;;
  restart) _restart ;;
  status)  _status  ;;
  *)
    echo "Usage: $0 {start|stop|restart|status}"
    exit 1
    ;;
esac
